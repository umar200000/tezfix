# Tezfix Caddyfile
#
# ── HTTPS via sslip.io (no domain needed) ────────────────────────────────────
# 46-8-176-235.sslip.io  →  resolves to 46.8.176.235  (free wildcard DNS)
# Caddy auto-gets a Let's Encrypt certificate for this domain.
#
# Telegram bot webhook:  https://46-8-176-235.sslip.io/api/...
# Telegram Mini App URL: https://46-8-176-235.sslip.io
#
# ── Switch to real domain later ───────────────────────────────────────────────
# Replace "46-8-176-235.sslip.io" with "tezfix.uz" and git push.
# ─────────────────────────────────────────────────────────────────────────────

46-8-176-235.sslip.io {
    encode zstd gzip

    # API & uploads → Fastify:3000
    handle /api/* {
        reverse_proxy localhost:3000
    }
    handle /uploads/* {
        reverse_proxy localhost:3000
    }

    # Admin SPA (sub-path)
    handle_path /admin/* {
        root * /opt/tezfix/apps/admin/dist
        try_files {path} /index.html
        file_server
    }
    redir /admin /admin/ permanent

    # Web SPA (catch-all)
    handle {
        root * /opt/tezfix/apps/web/dist
        try_files {path} /index.html
        file_server
    }

    log {
        output file /var/log/caddy/tezfix-access.log {
            roll_size 10mb
            roll_keep 5
        }
    }
}
