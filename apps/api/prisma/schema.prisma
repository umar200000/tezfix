generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         Int      @id @default(autoincrement())
  telegramId String   @unique @map("telegram_id")
  firstName  String?  @map("first_name")
  lastName   String?  @map("last_name")
  name       String
  username   String?
  phone      String?
  photoUrl   String?  @map("photo_url")
  avatar     String?
  isMaster   Boolean  @default(false) @map("is_master")
  isClient   Boolean  @default(false) @map("is_client")
  role       String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  services  Service[]
  leads     Lead[]     @relation("ClientLeads")
  favorites Favorite[]

  @@map("users")
}

model Service {
  id           Int      @id @default(autoincrement())
  ownerId      Int      @map("owner_id")
  name         String
  description  String?
  location     String?
  latitude     Float?
  longitude    Float?
  images       String   @default("[]") // JSON array of image paths
  servicesList String   @default("[]") @map("services_list") // JSON array
  bio          String?
  rating       Float    @default(0)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  owner     User       @relation(fields: [ownerId], references: [id])
  leads     Lead[]
  favorites Favorite[]

  @@map("services")
}

model Lead {
  id        Int      @id @default(autoincrement())
  serviceId Int      @map("service_id")
  clientId  Int      @map("client_id")
  status    String   @default("new") // kept for backwards compat
  createdAt DateTime @default(now()) @map("created_at")

  service Service @relation(fields: [serviceId], references: [id])
  client  User    @relation("ClientLeads", fields: [clientId], references: [id])

  @@map("leads")
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  serviceId Int      @map("service_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])

  @@unique([userId, serviceId])
  @@map("favorites")
}

model ServiceCategory {
  id   Int    @id @default(autoincrement())
  name String
  icon String
  slug String @unique

  @@map("service_categories")
}

model Banner {
  id        Int      @id @default(autoincrement())
  title     String
  subtitle  String?
  image     String   // /uploads/<file>
  link      String?
  isActive  Boolean  @default(true) @map("is_active")
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("banners")
}

model QuickService {
  id         Int      @id @default(autoincrement())
  name       String
  icon       String   @default("wrench") // slug from category icon set or emoji
  masterName String   @map("master_name")
  phone      String
  address    String
  description String?
  image      String?  // optional /uploads/<file>
  isActive   Boolean  @default(true) @map("is_active")
  order      Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("quick_services")
}
